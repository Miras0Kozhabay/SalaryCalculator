# PostgreSQL Configuration
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=salary_db

# SSL Mode for database connections
# Options: require (default, secure), disable (only for local dev), prefer
DB_SSL_MODE=require

# Server Configuration
SERVER_PORT=8080

# МРП (Minimum Pension Amount) for tax calculations
# For 2025: 3932 KZT
# Update this value each year according to government decree
MCI=3932
